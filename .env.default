# ─── codecheck default configuration ───
# Copy this file to .env and adjust as needed:  cp .env.default .env

# ─── Server ───
PORT=8000

# ─── Claude backend (pick ONE tier) ───
#
# Tier 1 (preferred): Claude Code CLI — no env vars needed, just install the claude CLI.
#   The app auto-detects the binary. Set CLAUDECODE=1 to force-skip the CLI
#   (e.g. when running inside a Claude Code session to avoid nested invocation).
# CLAUDECODE=

# Tier 2: AWS Bedrock — used when CLI is unavailable.
#   Requires the anthropic[bedrock] pip package and AWS credentials.
# AWS_PROFILE=bedrock
# AWS_DEFAULT_REGION=us-west-2
# ANTHROPIC_MODEL=us.anthropic.claude-sonnet-4-6-20250514

# Tier 3: Azure AI Foundry — used when CLI is unavailable.
#   Requires the anthropic pip package and Azure credentials.
#   See: https://docs.anthropic.com/en/docs/build-with-claude/azure
# AZURE_AI_FOUNDRY=1
# AZURE_ENDPOINT=https://<resource>.services.ai.azure.com
# AZURE_API_KEY=your-azure-api-key
# AZURE_API_VERSION=2025-04-01
# ANTHROPIC_MODEL=claude-sonnet-4-6-20250514

# ─── GitHub integration (optional) ───
#   Enables "File as GitHub Issue" and higher clone rate limits.
#   The gh CLI must be authenticated (gh auth login), OR set a token:
# GH_TOKEN=ghp_...
# GITHUB_TOKEN=ghp_...
